{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(qemu-*:*)",
      "Bash(binwalk:*)",
      "Bash(file:*)",
      "Bash(readelf:*)",
      "Bash(curl:*)",
      "Bash(nc:*)",
      "Bash(kill:*)",
      "Bash(ps:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(tar:*)",
      "Bash(gzip:*)",
      "Bash(unzip:*)",
      "Bash(strings:*)",
      "Bash(objdump:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[EMU-AGENT] Tool executed at $(date)' >> /tmp/emu_agent_audit.log"
          }
        ]
      }
    ]
  }
}
